        </mxCell>
        <mxCell id="n_pinhole" value="Pinhole Back-projection&#xa;x_cam=(u−cx)·Z/fx&#xa;y_cam=(v−cy)·Z/fy&#xa;z_cam=Z mm (real/fake fallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#b06000;fontColor=#5a2a00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="25" y="310" width="265" height="75" as="geometry" />
        </mxCell>
        <mxCell id="n_transform" value="Camera→Robot Transform&#xa;R=[[-1,0,0],[0,1,0],[0,0,-1]]&#xa;x_base=−x_cam  (TX=−50)&#xa;y_base=+y_cam+TY  (TY=+325)&#xa;z_base=−z_cam+TZ  (TZ=352)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#b06000;fontColor=#5a2a00;fontSize=11;" vertex="1" parent="1">
