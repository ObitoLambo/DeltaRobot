          <mxGeometry x="920" y="300" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_ik_val" value="validate_target / VISION_ONLY&#xa;delta_calcInverse → θ₁θ₂θ₃&#xa;delta_calcForward → FK verify"
