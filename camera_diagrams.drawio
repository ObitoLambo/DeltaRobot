          vertex="1" parent="1">
          <mxGeometry x="920" y="100" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_stable" value="is_stable(xyz_avg)&#xa;±1.5 mm X/Y  ±2.0 mm Z&#xa;over CENTER_WINDOW=5 frames"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b8e8c8;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="920" y="200" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_ws_chk" value="check_workspace(x, y, z)&#xa;(if DETECT_ONLY_IN_WORKSPACE)&#xa;|x|≤151.6  |y|≤151.6  z in range"
