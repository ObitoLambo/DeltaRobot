  <!-- ═══════════════════════════════════════════════════════════════════
       PAGE 2 — CAMERA PROCESSING WORKFLOW (per-frame flowchart)
       ═══════════════════════════════════════════════════════════════════ -->
  <diagram name="Camera Processing Workflow" id="cam_workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="900" pageHeight="2400"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <!-- ── Legend ── -->
        <mxCell id="leg_proc" value="Process"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="100" width="120" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="leg_dec" value="Decision"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="150" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg_pub" value="Publish / Output"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="216" width="120" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="leg_rej" value="Reject / Skip"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="266" width="120" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="leg_title" value="Legend"
          style="text;html=1;fontStyle=1;fontSize=13;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="72" width="120" height="24" as="geometry"/>
        </mxCell>

        <!-- ── MAIN FLOW ── -->

        <!-- 1. START -->
        <mxCell id="f_start" value="New Color Frame Received"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=13;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="220" y="30" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- 2. camera_info guard -->
        <mxCell id="f_caminfo" value="camera_info&#xa;ready?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="120" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_drop" value="Drop frame&#xa;(wait for camera_info)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="135" width="200" height="44" as="geometry"/>
        </mxCell>

        <!-- 3. Get depth -->
        <mxCell id="f_depth" value="Get cached depth image&#xa;(depth_callback stores latest)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="240" width="250" height="54" as="geometry"/>
        </mxCell>

        <!-- 4. Run detection -->
        <mxCell id="f_detect" value="Run detection engine&#xa;YOLO (mode=yolo)  or&#xa;white_rectangle (mode=white_rectangle)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="215" y="340" width="270" height="65" as="geometry"/>
        </mxCell>

        <!-- 5. Any detections? -->
        <mxCell id="f_det_q" value="Detections&#xa;found?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="455" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_nodet" value="no_detection_count++&#xa;Reset tracking state&#xa;if count &gt; LOST_RESET_FRAMES"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="462" width="210" height="56" as="geometry"/>
        </mxCell>

        <!-- 6. Per-detection loop -->
        <mxCell id="f_loop" value="For each detection (loop)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=12;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="580" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- 7. Frame bounds + box-like check -->
        <mxCell id="f_filter_q" value="Bounds check &amp;&#xa;box-like filter pass?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="680" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_rej1" value="Skip detection&#xa;(OUT_OF_FRAME / NOT_BOX)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="692" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- 8. Depth lookup -->
        <mxCell id="f_depth_lu" value="get_depth_meters(u, v)&#xa;5×5 window median&#xa;(uint16 → meters)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="800" width="250" height="65" as="geometry"/>
        </mxCell>

        <!-- 9. Depth valid? -->
        <mxCell id="f_depth_q" value="Depth&#xa;valid?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="915" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_rej2" value="Skip detection&#xa;(NO_DEPTH)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="930" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- 10. 3D projection -->
        <mxCell id="f_proj" value="pixel_to_camera_xyz_mm(u, v, z_m)&#xa;camera_to_base_mm&#xa;→ (x_base, y_base, z_base) mm"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="215" y="1035" width="270" height="65" as="geometry"/>
        </mxCell>

        <!-- 11. XYZ average -->
        <mxCell id="f_avg" value="update_xyz_average(track_id, xyz)&#xa;7-frame smoothing buffer&#xa;update_detection_confirmation()"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="215" y="1150" width="270" height="65" as="geometry"/>
        </mxCell>

        <!-- 12. Track confirmed? -->
        <mxCell id="f_track_q" value="Track confirmed&#xa;(≥ 2 frames)?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="1265" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_wait_track" value="reason = WAIT_TRACK&#xa;allowed = False"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="1278" width="200" height="44" as="geometry"/>
        </mxCell>

        <!-- 13. Stable? -->
        <mxCell id="f_stable_q" value="Position&#xa;stable?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="1385" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_not_stable" value="reason = NOT_STABLE&#xa;allowed = False"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="1398" width="200" height="44" as="geometry"/>
        </mxCell>

        <!-- 14. VISION_ONLY / IK valid? -->
        <mxCell id="f_vision_q" value="VISION_ONLY_ENABLE&#xa;or IK + FK valid?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="1505" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_allowed_t" value="allowed = True&#xa;reason = OK"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="1510" width="200" height="44" as="geometry"/>
        </mxCell>

        <mxCell id="f_allowed_f" value="allowed = False&#xa;reason = IK_FAIL / WS_FAIL"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="1575" width="200" height="44" as="geometry"/>
        </mxCell>

        <!-- 15. Add candidate -->
        <mxCell id="f_candidate" value="Add to candidate list&#xa;(best = minimum Z distance)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="1670" width="250" height="54" as="geometry"/>
        </mxCell>

        <!-- loop back arrow from candidate → loop -->
        <mxCell id="f_next_det" value="next detection"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_candidate" target="f_loop" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="1697"/>
              <mxPoint x="170" y="605"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 16. Select best -->
        <mxCell id="f_select" value="Select best candidate&#xa;(minimum Z distance from robot)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="1780" width="250" height="54" as="geometry"/>
        </mxCell>

        <!-- 17. Publish status -->
        <mxCell id="f_pub_status" value="Publish /delta/detection_status&#xa;(always — reason string)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="1885" width="250" height="54" as="geometry"/>
        </mxCell>

        <!-- 18. allowed? -->
        <mxCell id="f_allowed_q" value="allowed&#xa;= True?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="1985" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_skip_pub" value="Do not publish target&#xa;(not ready / unstable)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="530" y="1998" width="200" height="44" as="geometry"/>
        </mxCell>

        <!-- 19. Publish target -->
        <mxCell id="f_pub_target" value="Publish /delta/target_xyz&#xa;(geometry_msgs/PointStamped)&#xa;frame=robot_base, units=m"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="215" y="2105" width="270" height="65" as="geometry"/>
        </mxCell>

        <!-- 20. Show frame -->
        <mxCell id="f_show" value="Display annotated frame&#xa;cv2.imshow  (if VIEW_IMAGE=True)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="2220" width="250" height="54" as="geometry"/>
        </mxCell>

        <!-- 21. END -->
        <mxCell id="f_end" value="END FRAME"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=13;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="235" y="2320" width="230" height="50" as="geometry"/>
        </mxCell>

        <!-- ══ Flow edges ══ -->
        <mxCell id="w01" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_start" target="f_caminfo" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w02" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_caminfo" target="f_depth" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w03" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;fontColor=#cc0000;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_caminfo" target="f_drop" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w04" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_depth" target="f_detect" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w05" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_detect" target="f_det_q" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w06" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_det_q" target="f_loop" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w07" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;fontColor=#cc0000;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_det_q" target="f_nodet" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w08" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4a1a6a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_loop" target="f_filter_q" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w09" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_filter_q" target="f_depth_lu" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w10" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;fontColor=#cc0000;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_filter_q" target="f_rej1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w11" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_depth_lu" target="f_depth_q" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w12" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_depth_q" target="f_proj" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w13" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;fontColor=#cc0000;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_depth_q" target="f_rej2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w14" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_proj" target="f_avg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w15" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_avg" target="f_track_q" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w16" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_track_q" target="f_stable_q" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w17" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;fontColor=#cc0000;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_track_q" target="f_wait_track" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w18" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_stable_q" target="f_vision_q" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w19" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;fontColor=#cc0000;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_stable_q" target="f_not_stable" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w20" value="Yes" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_vision_q" target="f_allowed_t" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w21" value="No" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;fontColor=#cc0000;fontSize=10;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="f_vision_q" target="f_allowed_f" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- allowed_t + allowed_f + wait_track + not_stable → candidate -->
        <mxCell id="w22" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a4a2a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_vision_q" target="f_candidate" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w23" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.7;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_wait_track" target="f_candidate" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w24" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#cc0000;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.8;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_not_stable" target="f_candidate" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- candidate → select → pub_status → allowed_q -->
        <mxCell id="w25" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_candidate" target="f_select" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="w26" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1a3a5c;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="f_select" target="f_pub_status" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

