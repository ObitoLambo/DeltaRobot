          <mxGeometry x="272" y="295" width="256" height="65" as="geometry"/>
        </mxCell>

        <!-- ── Detection engine nodes ── -->
        <mxCell id="n_yolo" value="YOLO (ultralytics)&#xa;model: yolo11n.pt&#xa;conf_thres=0.25  iou=0.45"
