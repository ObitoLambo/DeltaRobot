          vertex="1" parent="1">
          <mxGeometry x="920" y="400" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_config" value="config.py  (runtime settings)&#xa;&#xa;DETECTION_MODE  YOLO_MODEL&#xa;CONF_THRES  YOLO_IMGSZ&#xa;CAM_TX/TY/TZ_MM&#xa;CAMERA_DIRECT_MATRIX&#xa;STABLE_THRESH_X/Y/Z_MM&#xa;AUTO_MOVE  ENABLE_MOTORS&#xa;VISION_ONLY_ENABLE"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="1130" y="100" width="255" height="250" as="geometry"/>
        </mxCell>

        <!-- ── ROS output nodes ── -->
        <mxCell id="n_target_pub" value="/delta/target_xyz&#xa;(geometry_msgs/PointStamped)&#xa;frame=robot_base  units=m&#xa;published when allowed=True"
