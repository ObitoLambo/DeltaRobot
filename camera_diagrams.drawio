          <mxGeometry x="610" y="100" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_wrect" value="white_rectangle (OpenCV)&#xa;Canny + contour + brightness&#xa;+ rectangularity filter"
