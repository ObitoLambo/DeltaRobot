        </mxCell>
        <!-- ── FSM node ── -->
        <mxCell id="n_fsm" value="main_app.py  FSM&#xa;(background thread)&#xa;ORCHESTRATES THE SEQUENCE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b8e8c8;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=13;fontStyle=1;" vertex="1" parent="1">
