          <mxGeometry x="610" y="190" width="255" height="65" as="geometry"/>
        </mxCell>

        <!-- ── 3D pipeline nodes ── -->
        <mxCell id="n_depth_lu" value="get_depth_meters(u, v)&#xa;5×5 window median&#xa;stale-depth protection"
