          <mxGeometry x="610" y="505" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_homoplane" value="estimate_plane_center_and_yaw&#xa;(if corners detected)&#xa;homography-based XY"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b8e8c8;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="610" y="595" width="255" height="65" as="geometry"/>
        </mxCell>

        <!-- ── Tracking + stability nodes ── -->
        <mxCell id="n_avg" value="update_xyz_average&#xa;7-frame smoothing buffer&#xa;per track_id"
