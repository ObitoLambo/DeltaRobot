        </mxCell>
        <!-- ── EE correction node ── -->
        <mxCell id="n_ee_corr" value="EE Feedforward Correction&#xa;(X-axis only, max 3 iters)&#xa;err_x = obj.x − ee.x&#xa;x_new = x − err_x × 0.6&#xa;stop: |err_x| &lt; 5mm or 2s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8f5c8;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="370" width="270" height="95" as="geometry" />
        </mxCell>
        <!-- ── delta_common nodes ── -->
