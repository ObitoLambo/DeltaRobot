          <mxGeometry x="610" y="415" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_transform" value="camera_to_base_mm&#xa;rotation matrix + translation&#xa;(CAM_TX/TY/TZ, CAMERA_DIRECT_MATRIX)"
