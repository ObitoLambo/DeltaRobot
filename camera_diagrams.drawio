          <mxGeometry x="272" y="75" width="256" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_depth_t" value="/camera/camera/aligned_depth_to_color/image_raw&#xa;(sensor_msgs/Image)&#xa;Depth aligned to color"
