        <mxCell id="n_ik" value="delta_calcInverse(x, y, z)&#xa;IK → (θ₁, θ₂, θ₃)&#xa;e=35 f=157 re=400 rf=200&#xa;Rejects θ &lt; 0  [enforced]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e4ccf5;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=11;fontStyle=1;" vertex="1" parent="1">
