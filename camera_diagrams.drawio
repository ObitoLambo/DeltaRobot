          <mxGeometry x="610" y="325" width="255" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_proj" value="pixel_to_camera_xyz_mm(u, v, z)&#xa;x = (u−cx)·z/fx&#xa;→ (x_cam, y_cam, z_cam) mm"
