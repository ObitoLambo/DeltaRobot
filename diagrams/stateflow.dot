digraph StateFlow {
    graph [
        label="Blind Pick-and-Place — State Flow"
        labelloc=t
        fontname="Helvetica Bold"
        fontsize=22
        bgcolor="white"
        pad=0.7
        splines=polyline
        nodesep=0.7
        ranksep=1.0
        rankdir=TB
    ]
    node [
        shape=box
        style="filled,rounded"
        fontname="Helvetica"
        fontsize=14
        margin="0.35,0.2"
        penwidth=2.5
    ]
    edge [
        fontname="Helvetica"
        fontsize=11
        penwidth=2.0
        arrowsize=0.9
    ]

    // ── States ────────────────────────────────────────────────────────────────
    IDLE         [label="IDLE",          fillcolor="#dce8f5" fontcolor="#1a3a5c" color="#1a3a5c"]
    APPROACHING  [label="APPROACHING",   fillcolor="#d6f0e0" fontcolor="#1a4a2a" color="#1a4a2a"]
    PICKING      [label="PICKING",       fillcolor="#d6f0e0" fontcolor="#1a4a2a" color="#1a4a2a"]
    GRASPING     [label="GRASPING",      fillcolor="#ede0f7" fontcolor="#4a1a6a" color="#4a1a6a"]
    LIFTING      [label="LIFTING",       fillcolor="#d6f0e0" fontcolor="#1a4a2a" color="#1a4a2a"]
    TRANSPORTING [label="TRANSPORTING",  fillcolor="#d6f0e0" fontcolor="#1a4a2a" color="#1a4a2a"]
    DROPPING     [label="DROPPING",      fillcolor="#ede0f7" fontcolor="#4a1a6a" color="#4a1a6a"]
    RESETTING    [label="RESETTING",     fillcolor="#dce8f5" fontcolor="#1a3a5c" color="#1a3a5c"]
    ERROR        [label="ERROR\n(abort + safety open)",
                  fillcolor="#fde0e0" fontcolor="#8b0000" color="#cc0000"
                  style="filled,rounded,dashed" penwidth=2.5]

    // ── Happy path ────────────────────────────────────────────────────────────
    IDLE         -> APPROACHING  [label="  trigger received\n  (service call / blind_target topic)"
                                  color="#1a4a2a" fontcolor="#1a4a2a"]
    APPROACHING  -> PICKING      [label="  arrived at approach height\n  (pick_z + 50 mm)"
                                  color="#1a4a2a" fontcolor="#1a4a2a"]
    PICKING      -> GRASPING     [label="  descended to pick_z\n  (slow, v=40 mm/s)"
                                  color="#1a4a2a" fontcolor="#1a4a2a"]
    GRASPING     -> LIFTING      [label="  gripper CLOSED  →  CAN 004#01\n  wait close_settle_s"
                                  color="#4a1a6a" fontcolor="#4a1a6a"]
    LIFTING      -> TRANSPORTING [label="  lifted to pick_z + 70 mm"
                                  color="#1a4a2a" fontcolor="#1a4a2a"]
    TRANSPORTING -> DROPPING     [label="  arrived at drop position\n  (drop_x, drop_y, drop_z)"
                                  color="#1a4a2a" fontcolor="#1a4a2a"]
    DROPPING     -> RESETTING    [label="  gripper OPEN  →  CAN 004#00\n  wait open_settle_s"
                                  color="#4a1a6a" fontcolor="#4a1a6a"]
    RESETTING    -> IDLE         [label="  returned to HOME  (0, 0, −300 mm)"
                                  color="#1a3a5c" fontcolor="#1a3a5c"]

    // ── Error transitions ─────────────────────────────────────────────────────
    APPROACHING  -> ERROR [label="trajectory\nfailure" style=dashed color="#cc0000" fontcolor="#cc0000"]
    PICKING      -> ERROR [label="trajectory\nfailure" style=dashed color="#cc0000" fontcolor="#cc0000"]
    LIFTING      -> ERROR [label="trajectory\nfailure" style=dashed color="#cc0000" fontcolor="#cc0000"]
    TRANSPORTING -> ERROR [label="trajectory\nfailure" style=dashed color="#cc0000" fontcolor="#cc0000"]
    ERROR        -> RESETTING [label="  go home" style=dashed color="#cc0000" fontcolor="#cc0000"]

    // ── Busy guard ────────────────────────────────────────────────────────────
    IDLE -> IDLE [label="  trigger while busy → dropped"
                  style=dashed color="#999999" fontcolor="#999999"]
}
