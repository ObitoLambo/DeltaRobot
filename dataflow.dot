digraph DataFlow {
    graph [
        label="Blind Pick-and-Place — Data Flow"
        labelloc=t
        fontname="Helvetica Bold"
        fontsize=22
        bgcolor="white"
        pad=0.8
        splines=ortho
        nodesep=1.0
        ranksep=1.2
        rankdir=LR
    ]
    node [
        shape=box
        style="filled,rounded"
        fontname="Helvetica"
        fontsize=12
        margin="0.3,0.2"
        penwidth=2.0
    ]
    edge [
        fontname="Helvetica"
        fontsize=10
        penwidth=1.8
        arrowsize=0.85
    ]

    // ── Trigger inputs ────────────────────────────────────────────────────────
    subgraph cluster_triggers {
        label="Inputs / Triggers"
        fontname="Helvetica Bold" fontsize=13 fontcolor="#1a3a5c"
        style="filled" fillcolor="#eef4fb" color="#1a3a5c" penwidth=1.8

        SVC   [label="/delta/trigger_pick\n(std_srvs/Empty)"
               fillcolor="#c8ddf5" fontcolor="#1a3a5c" color="#1a3a5c"]
        TOPIC [label="/delta/blind_target\n(geometry_msgs/PointStamped)\n(x, y, z) mm"
               fillcolor="#c8ddf5" fontcolor="#1a3a5c" color="#1a3a5c"]
        PARAMS[label="ROS Parameters\npick_x / pick_y / pick_z\ndrop_x / drop_y / drop_z\napproach_z_offset = 50 mm\nlift_z_offset     = 70 mm\nv_max=80  a_max=200  dt=0.05\npneumatic_can_id  = 4\npneumatic_can_channel = can0"
               fillcolor="#fff5cc" fontcolor="#5a4000" color="#b08000" penwidth=2.0]
    }

    // ── Main ROS node ─────────────────────────────────────────────────────────
    subgraph cluster_node {
        label="ROS 2 Node: blind_pick_place"
        fontname="Helvetica Bold" fontsize=13 fontcolor="#1a4a2a"
        style="filled" fillcolor="#edf7f0" color="#1a4a2a" penwidth=1.8

        FSM [label="BlindPickAndPlace\nFSM (background thread)\nORCHESTRATES THE SEQUENCE"
             fillcolor="#b8e8c8" fontcolor="#1a4a2a" color="#1a4a2a"
             width=2.8 penwidth=2.5]
    }

    // ── delta_common library ──────────────────────────────────────────────────
    subgraph cluster_common {
        label="delta_common  (kinematics + trajectory)"
        fontname="Helvetica Bold" fontsize=13 fontcolor="#4a1a6a"
        style="filled" fillcolor="#f5eefa" color="#4a1a6a" penwidth=1.8

        WS   [label="check_workspace(x, y, z)\n|x| <= 151.6 mm\n|y| <= 151.6 mm\n-500 <= z <= -196.9 mm"
              fillcolor="#e4ccf5" fontcolor="#4a1a6a" color="#4a1a6a"]
        TRAJ [label="linear_waypoints(start, end)\nTrapezoidal velocity profile\nYields Cartesian waypoints[]"
              fillcolor="#e4ccf5" fontcolor="#4a1a6a" color="#4a1a6a"]
        IK   [label="delta_calcInverse(x, y, z)\nSolves IK  →  (θ₁, θ₂, θ₃)\nRejects θ < 0  [enforced]"
              fillcolor="#e4ccf5" fontcolor="#4a1a6a" color="#4a1a6a"]
        FK   [label="delta_calcForward(θ₁, θ₂, θ₃)\nSolves FK  →  (x, y, z)\nUsed for position verification"
              fillcolor="#e4ccf5" fontcolor="#4a1a6a" color="#4a1a6a"]
    }

    // ── Motor controller ──────────────────────────────────────────────────────
    subgraph cluster_motctrl {
        label="DeltaMotorController"
        fontname="Helvetica Bold" fontsize=13 fontcolor="#1a3a5c"
        style="filled" fillcolor="#eef4fb" color="#1a3a5c" penwidth=1.8

        CTRL [label="execute_trajectory(waypoints)\nmove_xyz(x, y, z)\nget_current_xyz()"
              fillcolor="#c8ddf5" fontcolor="#1a3a5c" color="#1a3a5c" width=2.4]
    }

    // ── CAN bus ───────────────────────────────────────────────────────────────
    subgraph cluster_can {
        label="CAN Bus  —  can0  @  1 Mbit/s"
        fontname="Helvetica Bold" fontsize=13 fontcolor="#7a3a00"
        style="filled" fillcolor="#fdf3e3" color="#b06000" penwidth=1.8

        M1 [label="Motor 1\nCAN ID 1\n(RS-00)" shape=cylinder fillcolor="#fddcaa" fontcolor="#5a2a00" color="#b06000"]
        M2 [label="Motor 2\nCAN ID 2\n(RS-00)" shape=cylinder fillcolor="#fddcaa" fontcolor="#5a2a00" color="#b06000"]
        M3 [label="Motor 3\nCAN ID 3\n(RS-00)" shape=cylinder fillcolor="#fddcaa" fontcolor="#5a2a00" color="#b06000"]
        PG [label="Pneumatic Gripper\nCAN ID 4\n004#01 = CLOSE\n004#00 = OPEN"
            shape=cylinder fillcolor="#fddcaa" fontcolor="#5a2a00" color="#b06000"]
    }

    // ── ROS output ────────────────────────────────────────────────────────────
    subgraph cluster_output {
        label="ROS Output"
        fontname="Helvetica Bold" fontsize=13 fontcolor="#005a5a"
        style="filled" fillcolor="#e8f7f7" color="#005a5a" penwidth=1.8

        STATE_PUB [label="/delta/robot_state\n(std_msgs/String)\nIDLE | APPROACHING | PICKING\nGRASPING | LIFTING | TRANSPORTING\nDROPPING | RESETTING"
                   fillcolor="#b8e8e8" fontcolor="#005a5a" color="#005a5a"]
    }

    // ── Edges ─────────────────────────────────────────────────────────────────
    // Inputs to FSM
    SVC    -> FSM [xlabel="pick coords\nfrom params"    color="#1a3a5c" fontcolor="#1a3a5c"]
    TOPIC  -> FSM [xlabel="(x,y,z) mm"                 color="#1a3a5c" fontcolor="#1a3a5c"]
    PARAMS -> FSM [xlabel="read on trigger"             color="#b08000" fontcolor="#b08000" style=dashed]

    // FSM -> delta_common
    FSM  -> WS   [xlabel="validate\nposition"           color="#4a1a6a" fontcolor="#4a1a6a"]
    FSM  -> TRAJ [xlabel="start + end\nv_max a_max dt"  color="#4a1a6a" fontcolor="#4a1a6a"]

    // delta_common -> motor controller
    TRAJ -> CTRL [xlabel="waypoints[]"                  color="#4a1a6a" fontcolor="#4a1a6a"]
    CTRL -> IK   [xlabel="(x,y,z)\nper step"            color="#4a1a6a" fontcolor="#4a1a6a"]
    IK   -> CTRL [xlabel="(θ₁,θ₂,θ₃) rad\nor reject"   color="#1a4a2a" fontcolor="#1a4a2a"]
    CTRL -> FK   [xlabel="θ feedback\n(degrees)"        color="#4a1a6a" fontcolor="#4a1a6a"]
    FK   -> CTRL [xlabel="(x,y,z) + err\nverification"  color="#1a4a2a" fontcolor="#1a4a2a"]

    // Motor controller -> CAN motors
    CTRL -> M1   [xlabel="pos target\n(rad)"            color="#b06000" fontcolor="#b06000"]
    CTRL -> M2   [xlabel="pos target\n(rad)"            color="#b06000" fontcolor="#b06000"]
    CTRL -> M3   [xlabel="pos target\n(rad)"            color="#b06000" fontcolor="#b06000"]

    // Motor feedback
    M1   -> CTRL [xlabel="mech_pos"                     color="#b06000" fontcolor="#b06000" style=dashed]
    M2   -> CTRL [xlabel="mech_pos"                     color="#b06000" fontcolor="#b06000" style=dashed]
    M3   -> CTRL [xlabel="mech_pos"                     color="#b06000" fontcolor="#b06000" style=dashed]

    // FSM -> gripper + state publisher
    FSM  -> PG        [xlabel="CAN 004#01 CLOSE\nCAN 004#00 OPEN"  color="#b06000" fontcolor="#b06000"]
    FSM  -> STATE_PUB [xlabel="FSM state\nstring"                  color="#005a5a" fontcolor="#005a5a"]
}
