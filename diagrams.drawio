<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0" compressed="false">

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAGE 1 — STATE FLOW
       ═══════════════════════════════════════════════════════════════════════ -->
  <diagram name="State Flow" id="stateflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="900" pageHeight="1400"
                  math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── Legend ── -->
        <mxCell id="leg_motion" value="Motion state"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="160" width="130" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="leg_gripper" value="Gripper state"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="210" width="130" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="leg_idle" value="Idle / Reset state"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="260" width="130" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="leg_error" value="Error state"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=11;dashed=1;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="310" width="130" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="leg_title" value="Legend"
          style="text;html=1;fontStyle=1;fontSize=13;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="130" height="24" as="geometry"/>
        </mxCell>

        <!-- ── State nodes ── -->
        <mxCell id="n_idle" value="IDLE"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="40" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_app" value="APPROACHING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="180" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_pick" value="PICKING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="320" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_grasp" value="GRASPING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="460" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_lift" value="LIFTING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="600" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_trans" value="TRANSPORTING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="740" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_drop" value="DROPPING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="880" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_reset" value="RESETTING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=15;fontStyle=1;arcSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="1020" width="220" height="54" as="geometry"/>
        </mxCell>

        <mxCell id="n_error" value="ERROR&#xa;(abort + safety open)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#cc0000;fontColor=#8b0000;fontSize=14;fontStyle=1;arcSize=30;dashed=1;"
          vertex="1" parent="1">
          <mxGeometry x="560" y="595" width="210" height="64" as="geometry"/>
        </mxCell>

        <!-- ── Happy path ── -->
        <mxCell id="e01" value="trigger received&#xa;(service call / blind_target topic)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a4a2a;fontColor=#1a4a2a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_idle" target="n_app" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e02" value="arrived at approach height&#xa;(pick_z + 50 mm)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a4a2a;fontColor=#1a4a2a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_app" target="n_pick" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e03" value="descended to pick_z&#xa;(v = 40 mm/s)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a4a2a;fontColor=#1a4a2a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_pick" target="n_grasp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e04" value="gripper CLOSED → CAN 004#01&#xa;wait close_settle_s"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_grasp" target="n_lift" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e05" value="lifted to pick_z + 70 mm"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a4a2a;fontColor=#1a4a2a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_lift" target="n_trans" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e06" value="arrived at drop position&#xa;(drop_x, drop_y, drop_z)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a4a2a;fontColor=#1a4a2a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_trans" target="n_drop" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e07" value="gripper OPEN → CAN 004#00&#xa;wait open_settle_s"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_drop" target="n_reset" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- RESETTING → IDLE  (loop up the right side) -->
        <mxCell id="e08" value="returned to HOME (0, 0, −300 mm)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a3a5c;fontColor=#1a3a5c;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_reset" target="n_idle" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="530" y="1047"/>
              <mxPoint x="530" y="67"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- IDLE self-loop: trigger while busy -->
        <mxCell id="e09" value="trigger while busy → dropped"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#999999;fontColor=#888888;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_idle" target="n_idle" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="190" y="67"/>
              <mxPoint x="190" y="30"/>
              <mxPoint x="350" y="30"/>
              <mxPoint x="350" y="40"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ── Error transitions (dashed red) ── -->
        <mxCell id="ea1" value="trajectory failure"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#cc0000;fontColor=#cc0000;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_app" target="n_error" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ea2" value="trajectory failure"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#cc0000;fontColor=#cc0000;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.2;entryDx=0;entryDy=0;"
          edge="1" source="n_pick" target="n_error" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ea3" value="trajectory failure"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#cc0000;fontColor=#cc0000;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_lift" target="n_error" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ea4" value="trajectory failure"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#cc0000;fontColor=#cc0000;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;"
          edge="1" source="n_trans" target="n_error" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ERROR → RESETTING -->
        <mxCell id="ea5" value="go home (safety)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#cc0000;fontColor=#cc0000;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_error" target="n_reset" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAGE 2 — DATA FLOW
       ═══════════════════════════════════════════════════════════════════════ -->
  <diagram name="Data Flow" id="dataflow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1700" pageHeight="900"
                  math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── Cluster background rectangles ── -->
        <mxCell id="bg_trig" value="Inputs / Triggers"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fb;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=5;"
          vertex="1" parent="1">
          <mxGeometry x="10" y="40" width="290" height="560" as="geometry"/>
        </mxCell>

        <mxCell id="bg_common" value="delta_common  (kinematics + trajectory)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5eefa;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=5;"
          vertex="1" parent="1">
          <mxGeometry x="660" y="10" width="290" height="610" as="geometry"/>
        </mxCell>

        <mxCell id="bg_ctrl" value="DeltaMotorController"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fb;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=5;"
          vertex="1" parent="1">
          <mxGeometry x="1000" y="160" width="290" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="bg_can" value="CAN Bus — can0  @  1 Mbit/s"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf3e3;strokeColor=#b06000;fontColor=#7a3a00;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=5;"
          vertex="1" parent="1">
          <mxGeometry x="1340" y="40" width="220" height="630" as="geometry"/>
        </mxCell>

        <mxCell id="bg_out" value="ROS Output"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f7f7;strokeColor=#005a5a;fontColor=#005a5a;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=5;"
          vertex="1" parent="1">
          <mxGeometry x="355" y="520" width="290" height="150" as="geometry"/>
        </mxCell>

        <!-- ── Trigger nodes ── -->
        <mxCell id="n_svc" value="/delta/trigger_pick&#xa;(std_srvs/Empty)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8ddf5;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="100" width="250" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="n_topic" value="/delta/blind_target&#xa;(geometry_msgs/PointStamped)&#xa;pick position (x, y, z) in mm"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8ddf5;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="200" width="250" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="n_params" value="ROS Parameters&#xa;&#xa;pick_x / pick_y / pick_z&#xa;drop_x / drop_y / drop_z&#xa;approach_z_offset = 50 mm&#xa;lift_z_offset     = 70 mm&#xa;v_max = 80 mm/s&#xa;a_max = 200 mm/s²&#xa;dt    = 0.05 s&#xa;pneumatic_can_id  = 4&#xa;pneumatic_can_channel = can0"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="310" width="250" height="260" as="geometry"/>
        </mxCell>

        <!-- ── FSM node ── -->
        <mxCell id="n_fsm" value="BlindPickAndPlace&#xa;FSM  (background thread)&#xa;ORCHESTRATES THE SEQUENCE"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b8e8c8;strokeColor=#1a4a2a;fontColor=#1a4a2a;fontSize=13;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="360" y="220" width="270" height="80" as="geometry"/>
        </mxCell>

        <!-- ── delta_common nodes ── -->
        <mxCell id="n_ws" value="check_workspace(x, y, z)&#xa;|x| ≤ 151.6 mm    |y| ≤ 151.6 mm&#xa;−500 ≤ z ≤ −196.9 mm"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e4ccf5;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="675" y="70" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="n_traj" value="linear_waypoints(start, end)&#xa;Trapezoidal velocity profile&#xa;Returns Cartesian waypoints[]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e4ccf5;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="675" y="180" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="n_ik" value="delta_calcInverse(x, y, z)&#xa;IK → (θ₁, θ₂, θ₃)&#xa;Rejects θ &lt; 0  [enforced]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e4ccf5;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="675" y="300" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="n_fk" value="delta_calcForward(θ₁, θ₂, θ₃)&#xa;FK → (x, y, z)&#xa;Position verification + error"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e4ccf5;strokeColor=#4a1a6a;fontColor=#4a1a6a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="675" y="420" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- ── Motor controller node ── -->
        <mxCell id="n_ctrl" value="execute_trajectory(waypoints)&#xa;move_xyz(x, y, z)&#xa;get_current_xyz()"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8ddf5;strokeColor=#1a3a5c;fontColor=#1a3a5c;fontSize=12;fontStyle=0;"
          vertex="1" parent="1">
          <mxGeometry x="1015" y="215" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- ── CAN motor nodes (cylinders) ── -->
        <mxCell id="n_m1" value="Motor 1&#xa;CAN ID 1  (RS-00)"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fddcaa;strokeColor=#b06000;fontColor=#5a2a00;fontSize=12;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="1360" y="100" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_m2" value="Motor 2&#xa;CAN ID 2  (RS-00)"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fddcaa;strokeColor=#b06000;fontColor=#5a2a00;fontSize=12;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="1360" y="220" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_m3" value="Motor 3&#xa;CAN ID 3  (RS-00)"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fddcaa;strokeColor=#b06000;fontColor=#5a2a00;fontSize=12;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="1360" y="340" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="n_pg" value="Pneumatic Gripper&#xa;CAN ID 4&#xa;004#01 = CLOSE&#xa;004#00 = OPEN"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fddcaa;strokeColor=#b06000;fontColor=#5a2a00;fontSize=12;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="1360" y="470" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- ── ROS Output node ── -->
        <mxCell id="n_out" value="/delta/robot_state  (std_msgs/String)&#xa;IDLE | APPROACHING | PICKING&#xa;GRASPING | LIFTING | TRANSPORTING&#xa;DROPPING | RESETTING"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b8e8e8;strokeColor=#005a5a;fontColor=#005a5a;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="365" y="565" width="270" height="90" as="geometry"/>
        </mxCell>

        <!-- ══ Edges ══ -->

        <!-- Triggers → FSM -->
        <mxCell id="d01" value="pick coords (from params)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a3a5c;fontColor=#1a3a5c;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;"
          edge="1" source="n_svc" target="n_fsm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d02" value="(x, y, z) mm"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a3a5c;fontColor=#1a3a5c;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_topic" target="n_fsm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d03" value="read on trigger"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#b08000;fontColor=#b08000;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;"
          edge="1" source="n_params" target="n_fsm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- FSM → check_workspace -->
        <mxCell id="d04" value="validate position"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_fsm" target="n_ws" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- FSM → linear_waypoints -->
        <mxCell id="d05" value="start + end points&#xa;v_max, a_max, dt"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_fsm" target="n_traj" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- TRAJ → CTRL -->
        <mxCell id="d06" value="waypoints[]"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;"
          edge="1" source="n_traj" target="n_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CTRL → IK (send xyz, get thetas) -->
        <mxCell id="d07" value="(x, y, z) per step"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=0;exitY=0.3;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;"
          edge="1" source="n_ctrl" target="n_ik" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- IK → CTRL (return thetas) -->
        <mxCell id="d08" value="(θ₁, θ₂, θ₃) rad  or  reject (−1)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a4a2a;fontColor=#1a4a2a;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;"
          edge="1" source="n_ik" target="n_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CTRL → FK (send theta feedback) -->
        <mxCell id="d09" value="θ feedback (degrees)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#4a1a6a;fontColor=#4a1a6a;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;"
          edge="1" source="n_ctrl" target="n_fk" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- FK → CTRL (return xyz + error) -->
        <mxCell id="d10" value="(x, y, z) + error mm"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#1a4a2a;fontColor=#1a4a2a;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;"
          edge="1" source="n_fk" target="n_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CTRL → Motors (position targets) -->
        <mxCell id="d11" value="pos target (rad)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#b06000;fontColor=#b06000;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_ctrl" target="n_m1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d12" value="pos target (rad)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#b06000;fontColor=#b06000;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_ctrl" target="n_m2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d13" value="pos target (rad)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#b06000;fontColor=#b06000;exitX=1;exitY=0.8;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_ctrl" target="n_m3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Motors → CTRL (feedback, dashed) -->
        <mxCell id="d14" value="mech_pos"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#b06000;fontColor=#b06000;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.2;entryDx=0;entryDy=0;"
          edge="1" source="n_m1" target="n_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d15" value="mech_pos"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#b06000;fontColor=#b06000;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_m2" target="n_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d16" value="mech_pos"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;strokeColor=#b06000;fontColor=#b06000;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.8;entryDx=0;entryDy=0;"
          edge="1" source="n_m3" target="n_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- FSM → Pneumatic Gripper -->
        <mxCell id="d17" value="CAN 004#01  CLOSE&#xa;CAN 004#00  OPEN"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#b06000;fontColor=#b06000;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="n_fsm" target="n_pg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- FSM → ROS Output -->
        <mxCell id="d18" value="FSM state string"
          style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#005a5a;fontColor=#005a5a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="n_fsm" target="n_out" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
