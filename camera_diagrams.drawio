          <mxGeometry x="272" y="185" width="256" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="n_info_t" value="/camera/camera/color/camera_info&#xa;(sensor_msgs/CameraInfo)&#xa;fx, fy, cx, cy, dist_coeffs"
