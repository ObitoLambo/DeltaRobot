          <mxGeometry x="345" y="100" width="240" height="65" as="geometry" />
        </mxCell>
        <mxCell id="n_params" value="ROS Parameters&#xa;&#xa;drop_x=0 / drop_y=−150 / drop_z=−410&#xa;approach_z_offset = 25 mm&#xa;lift_z_offset = 30 mm&#xa;v_max = 2000 mm/s  (medium)&#xa;a_max = 5000 mm/s²&#xa;dt = 0.05 s&#xa;pneumatic_can_id = 4&#xa;EE_CORRECTION_ENABLE = True&#xa;EE_CORRECTION_GAIN = 0.6&#xa;EE_CORRECTION_THRESH = 5mm&#xa;EE_CORRECTION_MAX_ITERS = 3&#xa;FAKE_DEPTH_ENABLE = True (fallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b08000;fontColor=#5a4000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
